@model CallCenterSecure.Models.SurveyTemplateViewModel

@{
    ViewBag.Title = "Create Survey Template";
}

<h2>Create Survey Template</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" role="alert">
        @TempData["ErrorMessage"]
    </div>
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(model => model.Name, htmlAttributes: new { @class = "control-label" })
        @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter template name" } })
        @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <input type="submit" value="Create" class="btn btn-primary" />
        @Html.RouteLink("Cancel", "SurveyTemplate", new { action = "Index" }, new { @class = "btn btn-secondary" })
    </div>
}

@section Scripts {
    @{ Html.RenderPartial("_ValidationScriptsPartial"); }
}