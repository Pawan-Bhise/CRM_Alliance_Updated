@model IEnumerable<CallCenterSecure.Models.SurveyTemplateType>

@{
    ViewBag.Title = "Survey Templates";
}

<h2>Survey Templates</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" role="alert">
        @TempData["ErrorMessage"]
    </div>
}

<p class="text-muted">Manage survey templates. Maximum of 3 templates allowed.</p>

@if (ViewBag.CanCreate)
{
    @Html.RouteLink("Create New Template", "SurveyTemplate", new { action = "Create" }, new { @class = "btn btn-primary mb-3" })
}
else
{
    <div class="alert alert-warning">Maximum of 3 templates reached. Delete one to create a new template.</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th style="width: 80px;">#</th>
            <th>Template Name</th>
            <th style="width: 200px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>
                    <div class="btn-group" role="group" aria-label="Template actions">
                        @Html.RouteLink("Edit", "SurveyTemplate", new { action = "Edit", id = item.Id }, new { @class = "btn btn-sm btn-primary me-1" })
                        @using (Html.BeginForm("Delete", "SurveyTemplate", FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('Are you sure you want to delete this template?');" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.Hidden("id", item.Id)
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
