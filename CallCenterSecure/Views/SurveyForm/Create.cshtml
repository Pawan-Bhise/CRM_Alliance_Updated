@model CallCenterSecure.Models.ViewModels.SurveyFormBuilderViewModel

@{
    ViewBag.Title = "Create Survey Form";
}

<h2>Create Survey Form</h2>
<p class="text-muted">Build a survey form under the selected survey template.</p>

@using (Html.BeginForm("Create", "SurveyForm", FormMethod.Post, new { id = "surveyFormBuilderForm" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(m => m.SurveyTemplateId)

    @Html.Partial("_SurveyFormBuilder", Model)

    <button type="submit" class="btn btn-primary">Create Form</button>
    @Html.RouteLink("Cancel", "SurveyForm", new { action = "Index", templateId = Model.SurveyTemplateId }, new { @class = "btn btn-secondary ms-2" })
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="@Url.Content("~/Scripts/survey-form-builder.js")"></script>
}
