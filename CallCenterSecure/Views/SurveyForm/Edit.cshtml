@model CallCenterSecure.Models.ViewModels.SurveyFormBuilderViewModel

@{
    ViewBag.Title = "Edit Survey Form";
}

<h2>Edit Survey Form</h2>
<p class="text-muted">Update the survey form details and questions.</p>

@using (Html.BeginForm("Edit", "SurveyForm", FormMethod.Post, new { id = "surveyFormBuilderForm" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(m => m.Id)
    @Html.HiddenFor(m => m.SurveyTemplateId)

    @Html.Partial("_SurveyFormBuilder", Model)

    <button type="submit" class="btn btn-primary">Update Form</button>
    @Html.RouteLink("Cancel", "SurveyForm", new { action = "Index", templateId = Model.SurveyTemplateId }, new { @class = "btn btn-secondary ms-2" })
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="@Url.Content("~/Scripts/survey-form-builder.js")"></script>
}
