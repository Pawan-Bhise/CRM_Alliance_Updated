            <div class="grid-wrapper mt-3">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between mb-2">
                            <strong>Grid Rows</strong>
                            <button type="button" class="btn btn-sm btn-outline-primary btn-add-grid-row">Add Row</button>
                        </div>
                        <div class="grid-row-list"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between mb-2">
                            <strong>Grid Columns</strong>
                            <button type="button" class="btn btn-sm btn-outline-primary btn-add-grid-column">Add Column</button>
                        </div>
                        <div class="grid-column-list"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</template>

<template id="optionTemplate">
    <div class="input-group mb-2 option-item">
        <input type="hidden" class="option-id" value="0" />
        <input type="hidden" class="option-order" value="0" />
        <input type="text" class="form-control option-text" placeholder="Option text" />
        <button type="button" class="btn btn-outline-danger btn-remove-option">Remove</button>
    </div>
</template>

<template id="gridRowTemplate">
    <div class="input-group mb-2 grid-row-item">
        <input type="hidden" class="grid-row-id" value="0" />
        <input type="hidden" class="grid-row-order" value="0" />
        <input type="text" class="form-control grid-row-text" placeholder="Row text" />
        <button type="button" class="btn btn-outline-danger btn-remove-grid-row">Remove</button>
    </div>
</template>

<template id="gridColumnTemplate">
    <div class="input-group mb-2 grid-column-item">
        <input type="hidden" class="grid-column-id" value="0" />
        <input type="hidden" class="grid-column-order" value="0" />
        <input type="text" class="form-control grid-column-text" placeholder="Column text" />
        <button type="button" class="btn btn-outline-danger btn-remove-grid-column">Remove</button>
    </div>
</template>
