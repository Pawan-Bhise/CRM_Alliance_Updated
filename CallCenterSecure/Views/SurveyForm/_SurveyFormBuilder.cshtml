                <button type="button" class="btn btn-sm btn-outline-danger btn-remove-question">Delete</button>
            </div>
        </div>
        <div class="card-body">
            <input type="hidden" class="question-id" value="0" />
            <input type="hidden" class="question-order" value="0" />

