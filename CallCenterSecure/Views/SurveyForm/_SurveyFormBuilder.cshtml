                        <option value="@SurveyQuestionTypeCatalog.MultipleChoice">@SurveyQuestionTypeCatalog.MultipleChoice</option>
                        <option value="@SurveyQuestionTypeCatalog.Checkboxes">@SurveyQuestionTypeCatalog.Checkboxes</option>
                        <option value="@SurveyQuestionTypeCatalog.Dropdown">@SurveyQuestionTypeCatalog.Dropdown</option>
                        <option value="@SurveyQuestionTypeCatalog.FileUpload">@SurveyQuestionTypeCatalog.FileUpload</option>
